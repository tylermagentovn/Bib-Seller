generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      AdminRole @default(EVENT_MANAGER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  events Event[]
}

model Event {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  rules       String?
  disclaimer  String?
  imageUrl    String?
  shirtSizeImageUrl String?
  raceKitImageUrl String?
  raceKitDescription String?
  location    String?
  eventDate   DateTime?
  status      EventStatus @default(DRAFT)
  fieldConfig                 Json?
  allowMultipleRegistrations  Boolean   @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById String?

  createdBy     Admin?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  distances     Distance[]
  registrations Registration[]
}

model Distance {
  id       String       @id @default(cuid())
  eventId  String
  name     String
  price    Int
  maxSlots Int
  bibStart Int
  bibEnd   Int
  type     DistanceType @default(SOLO)
  teamSize Int?

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@index([eventId])
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  password          String
  fullName          String?
  phone             String?
  gender            String?
  dob               DateTime?
  idNumber          String?
  shirtSize         String?
  bloodType         String?
  medicalConditions String?
  emergencyName     String?
  emergencyPhone    String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  registrations     Registration[]
}

model Registration {
  id             String             @id @default(cuid())
  eventId        String
  distanceId     String
  userId         String?
  fullName       String?
  phone          String?
  gender         String?
  email          String?
  dob            DateTime?
  idNumber       String?
  shirtSize      String?
  bloodType      String?
  medicalConditions String?
  emergencyName  String?
  emergencyPhone String?
  bibNumber           Int?
  disclaimerSignature String?
  disclaimerSignedAt  DateTime?
  status              RegistrationStatus @default(PENDING)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  event       Event        @relation(fields: [eventId], references: [id])
  distance    Distance     @relation(fields: [distanceId], references: [id])
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  payment     Payment?
  teamMembers TeamMember[]

  @@index([eventId])
  @@index([distanceId])
  @@index([email])
  @@index([userId])
}

model TeamMember {
  id                String    @id @default(cuid())
  registrationId    String
  memberIndex       Int
  fullName          String
  phone             String
  gender            String?
  email             String?
  dob               DateTime?
  idNumber          String?
  shirtSize         String?
  bloodType         String?
  medicalConditions String?
  emergencyName     String?
  emergencyPhone    String?
  createdAt         DateTime  @default(now())

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model Payment {
  id             String        @id @default(cuid())
  registrationId String        @unique
  amount         Int
  payosOrderCode    String?       @unique
  checkoutUrl       String?
  qrCode            String?
  bankBin           String?
  bankAccountNumber String?
  bankAccountName   String?
  payosRef          String?
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime      @default(now())

  registration Registration @relation(fields: [registrationId], references: [id])

  @@index([payosOrderCode])
}

enum AdminRole {
  SUPER_ADMIN
  EVENT_MANAGER
}

enum DistanceType {
  SOLO
  RELAY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum RegistrationStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
}
